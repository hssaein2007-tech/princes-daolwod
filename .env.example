BOT_TOKEN=123456:YOUR_BOT_TOKEN
BOT_NAME=الأمراء | 𝔞𝔩 𝔭𝔯𝔧𝔫𝔠𝔢𝔰
CANAL_URL=https://t.me/your_channel
SOURCE_URL=https://github.com/yourname/princes-bot
DEVELOPER_URL=https://t.me/your_username
START_PHOTO_URL=https://example.com/static-bot-image.jpg
COOKIES_FILE=/app/cookies.txt
MAX_UPLOAD_MB=49
DOWNLOAD_TIMEOUT=300
LOG_LEVEL=INFO
DOWNLOAD_DIR=/tmp/princes_downloads

# Instagram advanced mode (optional)
IG_LOGIN_USER=your_instagram_username
IG_SESSIONFILE=/app/session-your_instagram_username

# Telegram stories by username are NOT implemented in pure Bot API.
ENABLE_TELEGRAM_STORIES=false
